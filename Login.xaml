<Window x:Class="GenealogySystem.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="寻根溯源 - 系统登录" Height="480" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <!-- 定义统一的按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F7F9FC">
        <Border Background="White" CornerRadius="10" Margin="30" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" Opacity="0.1" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="族谱管理系统" FontSize="26" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#2C3E50"/>

                <TextBlock Text="用户名:" Margin="0,5,0,2"/>
                <TextBox x:Name="txtUsername" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="密码:" Margin="0,0,0,2"/>
                <PasswordBox x:Name="txtPassword" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,25"/>

                <!-- 登录按钮：使用统一样式 -->
                <Button x:Name="btnLogin" Content="登 录" Style="{StaticResource PrimaryButtonStyle}" Click="btnLogin_Click"/>

                <!-- 注册按钮：现在和登录按钮一模一样了 -->
                <Button x:Name="btnRegister" Content="注 册" Margin="0,15,0,0" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Background="#2ECC71" Click="btnRegister_Click"/>
                <!-- 注意：注册按钮我微调为了绿色 #2ECC71 以示区分，如果你想要纯一样，把 Background 删掉即可 -->

                <TextBlock Text="* 新用户注册后将自动创建个人族谱" Foreground="Gray" FontSize="11" 
                           HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>