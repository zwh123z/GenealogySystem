<Window x:Class="GenealogySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="“寻根溯源”族谱管理系统" Height="750" Width="1150" 
        WindowStartupLocation="CenterScreen" Background="#F4F7F9">
    
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BDC3C7"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="寻根溯源管理系统" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,5"/>

                <!-- 新增：当前用户信息显示 -->
                <TextBlock x:Name="lblWelcome" Text="欢迎登录" Foreground="#2ECC71" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Separator Margin="15,0,15,15" Background="#5D6D7E"/>

                <!-- 关键修改：族谱切换器 (满足多族谱查看需求) -->
                <TextBlock Text="📁 切换当前族谱：" Foreground="#BDC3C7" FontSize="11" Margin="20,0,0,5"/>
                <ComboBox x:Name="cbGenealogySelector" Margin="15,0,15,20" Height="30" 
                          DisplayMemberPath="Name" SelectedValuePath="Id"
                          SelectionChanged="cbGenealogySelector_SelectionChanged">
                    <!-- 后台动态加载 10 个族谱 -->
                </ComboBox>

                <!-- 导航按钮 -->
                <Button Content="📊 家族总览 " Style="{StaticResource NavButtonStyle}" Click="Nav_Dashboard_Click"/>
                <Button Content="👥 成员管理 " Style="{StaticResource NavButtonStyle}" Click="Nav_Members_Click"/>
                <Button Content="🌳 家族树预览 " Style="{StaticResource NavButtonStyle}" Click="Nav_Tree_Click"/>
                <Button Content="🔍 关系与通路查询" Style="{StaticResource NavButtonStyle}" Click="Nav_Query_Click"/>
                <Button Content="⚙️ 数据工程 " Style="{StaticResource NavButtonStyle}" Click="Nav_Data_Click"/>

                <Separator Margin="10,20" Background="#5D6D7E"/>
                <Button Content="🚪 退出系统" Click="btnExit_Click" Background="#E74C3C" Foreground="White" Height="35" Margin="15,0"/>
            </StackPanel>
        </Border>
        <!-- 右侧主内容区 -->
        <TabControl Grid.Column="1" x:Name="MainTabs" BorderThickness="0" Background="Transparent">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- Tab 0: Dashboard (增加个性化标题) -->
            <TabItem>
                <Grid Margin="30">
                    <StackPanel>
                        <TextBlock x:Name="lblDashTitle" Text="家族数据统计总览" FontSize="26" FontWeight="Bold" Margin="0,0,0,25" Foreground="#34495E"/>
                        <UniformGrid Columns="2">
                            <Border Background="White" CornerRadius="10" Padding="25" Margin="10" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="本族谱总人数" Foreground="#7F8C8D" FontSize="14"/>
                                    <TextBlock x:Name="lblTotalMembers" Text="0" FontSize="48" Foreground="#3498DB" FontWeight="Bold" Margin="0,10"/>
                                </StackPanel>
                            </Border>
                            <Border Background="White" CornerRadius="10" Padding="25" Margin="10" BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="男女比例 (男 : 女)" Foreground="#7F8C8D" FontSize="14"/>
                                    <TextBlock x:Name="lblGenderRatio" Text="0 : 0" FontSize="48" Foreground="#2ECC71" FontWeight="Bold" Margin="0,10"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 1: 成员管理 (保持你的结构，确保 ID 搜索存在) -->
            <TabItem>
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="搜索姓名:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSearchName" Width="100" Margin="8,0" TextChanged="txtSearchName_TextChanged" VerticalContentAlignment="Center"/>
                            <TextBlock Text="ID:" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSearchId" Width="60" Margin="8,0" TextChanged="txtSearchId_TextChanged" VerticalContentAlignment="Center"/>

                            <Button Content="➕ 新增" Click="btnAddNew_Click" Background="#27AE60" Foreground="White" Padding="12,3" Margin="10,0,5,0"/>
                            <Button Content="🔄 刷新" Click="btnRefresh_Click" Padding="10,3"/>
                            <Button Content="✉️ 邀请协作" Click="btnInvite_Click" Margin="10,0" Background="#8E44AD" Foreground="White" Padding="10,3"/>
                        </StackPanel>

                        <DataGrid x:Name="dgMembers" AutoGenerateColumns="False" IsReadOnly="True" 
                                  SelectionChanged="dgMembers_SelectionChanged" Background="White" RowHeight="32">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100"/>
                                <DataGridTextColumn Header="性别" Binding="{Binding Gender}" Width="50"/>
                                <DataGridTextColumn Header="出生年份" Binding="{Binding BirthYear}" Width="80"/>
                                <DataGridTextColumn Header="父ID" Binding="{Binding FatherId}" Width="50"/>
                                <DataGridTextColumn Header="母ID" Binding="{Binding MotherId}" Width="50"/>
                                <DataGridTextColumn Header="简介" Binding="{Binding Bio}" Width="*"/>
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="❌ 删除该成员" Click="btnDeleteMember_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </DockPanel>

                    <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#DCDFE6" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="📝 成员信息编辑" FontWeight="Bold" FontSize="16" Margin="0,0,0,20" Foreground="#2C3E50"/>
                                <TextBlock Text="姓名:"/>
                                <TextBox x:Name="edtName" Margin="0,5,0,15" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Text="性别:"/>
                                <ComboBox x:Name="edtGender" Margin="0,5,0,15" Height="28">
                                    <ComboBoxItem Content="男" IsSelected="True"/>
                                    <ComboBoxItem Content="女"/>
                                </ComboBox>
                                <TextBlock Text="出生年份:"/>
                                <TextBox x:Name="edtBirthYear" Margin="0,5,0,15" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Text="父亲 ID:"/>
                                <TextBox x:Name="edtFatherId" Margin="0,5,0,15" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Text="母亲 ID:"/>
                                <TextBox x:Name="edtMotherId" Margin="0,5,0,15" Height="28" VerticalContentAlignment="Center"/>
                                <TextBlock Text="备注/生平:"/>
                                <TextBox x:Name="edtBio" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,20"/>
                                <Button x:Name="btnSaveMember" Content="💾 保存信息" Click="btnSaveMember_Click" Height="40" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            <!-- Tab 2: 家族树 (保持不变) -->
            <TabItem>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🌳 家族传承图谱 (实时预览)" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                        <TreeView x:Name="tvFamilyTree" FontSize="14" BorderThickness="0"/>
                    </Border>
                </Grid>
            </TabItem>
            <!-- Tab 3: 高级查询 -->
            <TabItem>
                <Grid Margin="30">
                    <StackPanel MaxWidth="500" HorizontalAlignment="Left">
                        <GroupBox Header="历代祖先追溯" Margin="0,0,0,20" Padding="10">
                            <StackPanel>
                                <TextBox x:Name="txtAncestorId" Margin="0,5" Tag="输入成员ID"/>
                                <Button Content="追溯祖先" Click="btnShowAncestors_Click" Background="#3498DB" Foreground="White"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="亲缘路径计算" Padding="10">
                            <StackPanel>
                                <TextBox x:Name="txtPathId1" Margin="0,5" Tag="ID 1"/>
                                <TextBox x:Name="txtPathId2" Margin="0,5" Tag="ID 2"/>
                                <Button Content="寻找链路" Click="btnFindPath_Click" Background="#9B59B6" Foreground="White"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 4: 数据工程 -->
            <TabItem>
                <Grid Margin="30">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <TextBlock Text="数据工程工具" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                        <Border Background="White" Padding="20" CornerRadius="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="1. 模拟 10 万条数据生成" FontWeight="Bold"/>
                                <Button Content="生成 CSV (C:\temp\members.csv)" Margin="0,10" Click="btnGenerateCSV_Click" Background="#F39C12" Foreground="White"/>
                                <TextBlock Text="2. MySQL LOAD DATA 极速导入" FontWeight="Bold"/>
                                <Button Content="执行极速导入" Margin="0,10" Click="btnFastImport_Click" Background="#27AE60" Foreground="White"/>
                                <TextBlock Text="3. 分支备份" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <TextBox x:Name="txtExportId" Width="100" Margin="0,0,10,0"/>
                                    <Button x:Name="btnExportBranch" Content="导出备份" Click="btnExportBranch_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>